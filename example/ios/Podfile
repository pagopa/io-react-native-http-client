# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

platform :ios, min_ios_version_supported
prepare_react_native_project!

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
end

target 'IoReactNativeHttpClientExample' do
  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  target 'IoReactNativeHttpClientExampleTests' do
    inherit! :complete
    # Pods for testing
  end

  post_install do |installer|
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false
    )

    # Enforce minimum iOS deployment target for all pods to prevent the Swift
    # compiler from auto-linking swiftCompatibility56, which was removed in
    # Xcode 26. Any pod with a deployment target below 15.1 would cause a
    # linker failure because iOS 15.1+ ships with native Swift 5.6 runtime
    # support and no longer needs the compatibility shim.
    installer.pods_project.targets.each do |target|
      target.build_configurations.each do |config|
        current = config.build_settings['IPHONEOS_DEPLOYMENT_TARGET']
        if !current.nil? && current.to_f < 15.1
          config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '15.1'
        end
      end
    end

    # RCT-Folly 2024.11.18.00 shipped with RN 0.81 does not include folly/coro headers,
    # so force-disable coroutine paths to avoid including missing headers.
    installer.pods_project.targets.each do |target|
      target.build_configurations.each do |build_config|
        defs = build_config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] || ['$(inherited)']
        defs = Array(defs)
        unless defs.include?('FOLLY_CFG_NO_COROUTINES=1')
          defs << 'FOLLY_CFG_NO_COROUTINES=1'
        end
        unless defs.include?('FOLLY_HAS_COROUTINES=0')
          defs << 'FOLLY_HAS_COROUTINES=0'
        end
        build_config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] = defs
      end
    end

    installer.aggregate_targets.each do |aggregate_target|
      aggregate_target.user_project.native_targets.each do |target|
        target.build_configurations.each do |build_config|
          defs = build_config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] || ['$(inherited)']
          defs = Array(defs)
          unless defs.include?('FOLLY_CFG_NO_COROUTINES=1')
            defs << 'FOLLY_CFG_NO_COROUTINES=1'
          end
          unless defs.include?('FOLLY_HAS_COROUTINES=0')
            defs << 'FOLLY_HAS_COROUTINES=0'
          end
          build_config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] = defs
        end
      end
      aggregate_target.user_project.save
    end
  end
end
